# Environment variables for the geospatial research orchestrator.
# Copy to .env and fill in real values. NEVER commit .env with real keys.

# LLM (orchestrator / synthesis / validation). Any non-empty value works for vLLM.
OPENAI_API_KEY=
# Optional: point at a self-hosted / alternate OpenAI-compatible endpoint.
# OPENAI_BASE_URL=

# Research skill (Brave Search API). Get a key at https://api-dashboard.search.brave.com/
BRAVE_API_KEY=
