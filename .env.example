# Environment variables for the GeoContext environmental-research agent.
# Copy to .env and fill in real values. NEVER put real keys in THIS file —
# it is committed to the repo. Real keys go in .env (git-ignored; handler.py
# auto-loads it for local runs and never overrides real deployment env).

# ── LLM for the orchestrator (planning / synthesis / validation) ───────────
# The agent speaks the OpenAI Chat Completions format, so it works against ANY
# OpenAI-compatible endpoint — a free provider, hosted OpenAI, a self-hosted
# vLLM, or Anthropic (Claude). Set three vars: base URL, model, key.
# With NO key it still runs in a degraded, no-LLM heuristic mode.

# --- Recommended free default: Google Gemini (Flash) -----------------------
# ~1,500 requests/day free (≈500 full agent requests). Get a key at
# https://aistudio.google.com  ⚠️ use a Google Cloud project with billing
# DISABLED, or the free tier vanishes. Use a *Flash* model — Pro is paid-only.
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=

# --- Other OpenAI-compatible options (swap the three vars above) ------------
#   OpenAI (GPT):       OPENAI_BASE_URL= (unset)                        OPENAI_MODEL=gpt-4o-mini
#   Groq (fast, free):  OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_MODEL=llama-3.3-70b-versatile
#   OpenRouter (free):  OPENAI_BASE_URL=https://openrouter.ai/api/v1    OPENAI_MODEL=<a :free model>
#   Claude (Anthropic): OPENAI_BASE_URL=https://api.anthropic.com/v1/   OPENAI_MODEL=claude-opus-4-8
#   WashU shared vLLM:  OPENAI_BASE_URL=<their endpoint>                OPENAI_MODEL=<their served-model-name>

# ── Skill credentials ──────────────────────────────────────────────────────
# Research skill (Brave Search). Get a key at https://api-dashboard.search.brave.com/
BRAVE_API_KEY=

# Optional — identify the caller to USFWS IPaC (a header it will soon require).
# Non-secret identity values; safe to set. Any contact email / org / project.
# IPAC_CONTACT_EMAIL=
# IPAC_ORGANIZATION=WashU-DTRC-Research
# IPAC_PROJECT=geo-research-orchestrator
