# Copy to .env (and never commit the real .env).

# Required for the LLM tool loop (OpenAI Chat Completions or a compatible
# self-hosted endpoint, e.g. vLLM). Any non-empty placeholder works for vLLM.
OPENAI_API_KEY=sk-placeholder
# Uncomment + set if using a self-hosted vLLM endpoint instead of hosted OpenAI:
# OPENAI_BASE_URL=http://localhost:8000/v1

# Optional overrides (defaults live in config.py)
# AGENT_MODEL=gpt-4o-mini
# AGENT_A2A_HOST=0.0.0.0
# AGENT_A2A_PORT=9111
# AGENT_A2A_URL=http://your-deployed-host:9111/

# No API key is required for EPA ECHO, OpenStreetMap Nominatim, the Overpass
# API, USGS EPQS, or FEMA NFHL — all free public endpoints called directly
# from the tools/ package.
